}

// ─── Teachers Section ─────────────────────────────────────────────────────────

function TeachersSection() {
  const utils = trpc.useUtils();
  const { data: teachers = [] } = trpc.teachers.list.useQuery(undefined);
  const { data: schools = [] } = trpc.schools.list.useQuery();
  const [dialogOpen, setDialogOpen] = useState(false);
  const [editingTeacher, setEditingTeacher] = useState<Teacher | null>(null);
  const [uploadingId, setUploadingId] = useState<number | null>(null);
  const fileInputRef = useRef<HTMLInputElement>(null);

  const [form, setForm] = useState({
    name: "",
    subject: "",
    bio: "",
    schoolId: "",
    systemPrompt: "",
    active: "yes" as "yes" | "no",
  });

  const createMutation = trpc.teachers.create.useMutation({
    onSuccess: () => {
      utils.teachers.list.invalidate();
      toast.success("Professor cadastrado com sucesso!");
      setDialogOpen(false);
      resetForm();
    },
    onError: (e) => toast.error(e.message),
  });

  const updateMutation = trpc.teachers.update.useMutation({
    onSuccess: () => {
      utils.teachers.list.invalidate();
      toast.success("Professor atualizado!");
      setDialogOpen(false);
      setEditingTeacher(null);
      resetForm();
    },
    onError: (e) => toast.error(e.message),
  });

  const deleteMutation = trpc.teachers.delete.useMutation({
    onSuccess: () => { utils.teachers.list.invalidate(); toast.success("Professor removido."); },
    onError: (e) => toast.error(e.message),
  });

  const uploadMutation = trpc.teachers.uploadAvatar.useMutation({
    onSuccess: () => { utils.teachers.list.invalidate(); toast.success("Foto atualizada!"); setUploadingId(null); },
    onError: (e) => { toast.error(e.message); setUploadingId(null); },
  });

  const resetForm = () => setForm({ name: "", subject: "", bio: "", schoolId: "", systemPrompt: "", active: "yes" });

  const openCreate = () => {
    setEditingTeacher(null);
    resetForm();
    setDialogOpen(true);
  };

  const openEdit = (t: Teacher) => {
    setEditingTeacher(t);
    setForm({
      name: t.name,
      subject: t.subject,
      bio: t.bio ?? "",
      schoolId: t.schoolId?.toString() ?? "",
      systemPrompt: t.systemPrompt ?? "",
      active: t.active,
    });
    setDialogOpen(true);
  };

  const handleSubmit = () => {
    if (!form.name.trim() || !form.subject.trim()) {
      toast.error("Nome e matéria são obrigatórios.");
      return;
    }
    const data = {
      name: form.name,
      subject: form.subject,
      bio: form.bio || undefined,
      schoolId: form.schoolId ? parseInt(form.schoolId) : undefined,
      systemPrompt: form.systemPrompt || undefined,
    };
    if (editingTeacher) {
      updateMutation.mutate({ id: editingTeacher.id, ...data, active: form.active });
    } else {
      createMutation.mutate(data);
    }
  };

  const handleAvatarUpload = async (teacherId: number, file: File) => {
    setUploadingId(teacherId);
    const reader = new FileReader();
    reader.onload = () => {
      const base64 = (reader.result as string).split(",")[1];
      uploadMutation.mutate({
        teacherId,
        fileName: file.name,
        fileBase64: base64,
        mimeType: file.type,
      });
    };
    reader.readAsDataURL(file);
  };

  return (
    <div className="space-y-6">
      <div className="flex items-center justify-between">
        <div>
          <h2 className="text-2xl font-bold text-foreground" style={{ fontFamily: "Poppins, sans-serif" }}>
            Professores
          </h2>
          <p className="text-muted-foreground text-sm">{teachers.length} professor(es) cadastrado(s)</p>
        </div>
        <Button onClick={openCreate} className="gap-2">
          <Plus className="w-4 h-4" />
          Novo Professor
        </Button>
      </div>

      {teachers.length === 0 ? (
        <Card>
          <CardContent className="py-16 text-center">
            <GraduationCap className="w-12 h-12 text-muted-foreground mx-auto mb-4" />
            <p className="text-muted-foreground mb-4">Nenhum professor cadastrado ainda.</p>
            <Button onClick={openCreate} variant="outline" className="gap-2">
              <Plus className="w-4 h-4" />
              Cadastrar primeiro professor
            </Button>
          </CardContent>
        </Card>
      ) : (
        <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          {teachers.map((teacher) => {
            const school = schools.find((s) => s.id === teacher.schoolId);
            return (
              <Card key={teacher.id} className="overflow-hidden">
                <CardContent className="p-4">
                  <div className="flex items-start gap-3">
                    <div className="relative group">
                      <div className="w-14 h-14 rounded-full overflow-hidden bg-gradient-to-br from-primary/20 to-purple-500/20 flex items-center justify-center flex-shrink-0">
                        {teacher.avatarUrl ? (
                          <img src={teacher.avatarUrl} alt={teacher.name} className="w-full h-full object-cover" />
                        ) : (
                          <GraduationCap className="w-7 h-7 text-primary" />
                        )}
                      </div>
                      <button
                        className="absolute inset-0 rounded-full bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center"
                        onClick={() => {
                          setUploadingId(teacher.id);
                          fileInputRef.current?.click();
                        }}
                        title="Trocar foto"
                      >
                        <Upload className="w-4 h-4 text-white" />
                      </button>
                      <input
                        ref={fileInputRef}
                        type="file"
                        accept="image/*"
                        className="hidden"
                        onChange={(e) => {
                          const file = e.target.files?.[0];
                          if (file && uploadingId) handleAvatarUpload(uploadingId, file);
                          e.target.value = "";
                        }}
                      />
                    </div>
                    <div className="flex-1 min-w-0">
                      <div className="flex items-center gap-2">
                        <h3 className="font-semibold text-foreground truncate" style={{ fontFamily: "Poppins, sans-serif" }}>
                          {teacher.name}
                        </h3>
                        <Badge
                          variant={teacher.active === "yes" ? "default" : "secondary"}
                          className="text-xs flex-shrink-0"
                        >
                          {teacher.active === "yes" ? "Ativo" : "Inativo"}
                        </Badge>
                      </div>
                      <p className="text-sm text-primary font-medium">{teacher.subject}</p>
                      {school && <p className="text-xs text-muted-foreground">{school.name}</p>}
                      {teacher.bio && (
                        <p className="text-xs text-muted-foreground mt-1 line-clamp-2">{teacher.bio}</p>
                      )}
                    </div>
                  </div>
                  <div className="flex gap-2 mt-4">
                    <Button
                      variant="outline"
                      size="sm"
                      className="flex-1 gap-1.5"
                      onClick={() => openEdit(teacher)}
                    >
                      <Pencil className="w-3.5 h-3.5" />
                      Editar
                    </Button>
                    <Button
                      variant="outline"
                      size="sm"
                      className="text-destructive hover:text-destructive hover:bg-destructive/10"
                      onClick={() => {
                        if (confirm(`Remover ${teacher.name}?`)) deleteMutation.mutate({ id: teacher.id });
                      }}
                    >
                      <Trash2 className="w-3.5 h-3.5" />
                    </Button>
                  </div>
                </CardContent>
              </Card>
            );
          })}
        </div>
      )}

      {/* Teacher Dialog */}
      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>
        <DialogContent className="max-w-lg">
          <DialogHeader>
            <DialogTitle style={{ fontFamily: "Poppins, sans-serif" }}>
              {editingTeacher ? "Editar Professor" : "Novo Professor"}
            </DialogTitle>
          </DialogHeader>
          <div className="space-y-4 py-2">
            <div className="grid grid-cols-2 gap-4">
              <div className="space-y-1.5">
                <Label>Nome *</Label>
                <Input
                  value={form.name}
                  onChange={(e) => setForm((f) => ({ ...f, name: e.target.value }))}
                  placeholder="Nome completo"
                />
              </div>
              <div className="space-y-1.5">
                <Label>Matéria *</Label>
                <Input
                  value={form.subject}
                  onChange={(e) => setForm((f) => ({ ...f, subject: e.target.value }))}
                  placeholder="Ex: Matemática"
                />
              </div>
            </div>
            <div className="space-y-1.5">
              <Label>Escola</Label>
              <Select
                value={form.schoolId}
                onValueChange={(v) => setForm((f) => ({ ...f, schoolId: v }))}
              >
                <SelectTrigger>
                  <SelectValue placeholder="Selecionar escola (opcional)" />
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="none">Sem escola</SelectItem>
                  {schools.map((s) => (
                    <SelectItem key={s.id} value={s.id.toString()}>
                      {s.name}
                    </SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>
            <div className="space-y-1.5">
              <Label>Biografia</Label>
              <Textarea
                value={form.bio}
                onChange={(e) => setForm((f) => ({ ...f, bio: e.target.value }))}
                placeholder="Breve descrição do professor..."
                rows={2}
              />
            </div>
            <div className="space-y-1.5">
              <Label>Prompt do Sistema (personalidade da IA)</Label>
              <Textarea
                value={form.systemPrompt}
                onChange={(e) => setForm((f) => ({ ...f, systemPrompt: e.target.value }))}
                placeholder="Descreva como este professor deve se comportar, seu estilo de ensino, etc."
                rows={3}
              />
            </div>
            {editingTeacher && (
              <div className="space-y-1.5">
                <Label>Status</Label>
                <Select
                  value={form.active}
                  onValueChange={(v: "yes" | "no") => setForm((f) => ({ ...f, active: v }))}
                >
                  <SelectTrigger>
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="yes">Ativo</SelectItem>
                    <SelectItem value="no">Inativo</SelectItem>
                  </SelectContent>
                </Select>
              </div>
            )}
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => setDialogOpen(false)}>
              Cancelar
            </Button>
            <Button
              onClick={handleSubmit}
              disabled={createMutation.isPending || updateMutation.isPending}
            >
              {editingTeacher ? "Salvar alterações" : "Cadastrar professor"}
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </div>
  );
}

// ─── Schools Section ──────────────────────────────────────────────────────────

function SchoolsSection() {
  const utils = trpc.useUtils();
  const { data: schools = [] } = trpc.schools.list.useQuery();
  const [dialogOpen, setDialogOpen] = useState(false);
  const [editingSchool, setEditingSchool] = useState<School | null>(null);
  const [form, setForm] = useState({ name: "", city: "", state: "" });

  const createMutation = trpc.schools.create.useMutation({
    onSuccess: () => {
      utils.schools.list.invalidate();
      toast.success("Escola cadastrada!");
      setDialogOpen(false);
      setForm({ name: "", city: "", state: "" });
    },
    onError: (e) => toast.error(e.message),
  });

  const updateMutation = trpc.schools.update.useMutation({
    onSuccess: () => {
      utils.schools.list.invalidate();
      toast.success("Escola atualizada!");
      setDialogOpen(false);
      setEditingSchool(null);
    },
    onError: (e) => toast.error(e.message),
  });

  const deleteMutation = trpc.schools.delete.useMutation({
    onSuccess: () => { utils.schools.list.invalidate(); toast.success("Escola removida."); },
    onError: (e) => toast.error(e.message),
  });

  const openCreate = () => {
    setEditingSchool(null);
    setForm({ name: "", city: "", state: "" });
    setDialogOpen(true);
  };

  const openEdit = (s: School) => {
    setEditingSchool(s);
    setForm({ name: s.name, city: s.city ?? "", state: s.state ?? "" });
    setDialogOpen(true);
  };

  const handleSubmit = () => {
    if (!form.name.trim()) { toast.error("Nome da escola é obrigatório."); return; }
    const data = { name: form.name, city: form.city || undefined, state: form.state || undefined };
    if (editingSchool) {
      updateMutation.mutate({ id: editingSchool.id, ...data });
    } else {
      createMutation.mutate(data);
    }
  };

  return (
    <div className="space-y-6">
      <div className="flex items-center justify-between">
        <div>
          <h2 className="text-2xl font-bold text-foreground" style={{ fontFamily: "Poppins, sans-serif" }}>
            Escolas
          </h2>
          <p className="text-muted-foreground text-sm">{schools.length} escola(s) cadastrada(s)</p>
        </div>
        <Button onClick={openCreate} className="gap-2">
          <Plus className="w-4 h-4" />
          Nova Escola
        </Button>
      </div>

      {schools.length === 0 ? (
        <Card>
          <CardContent className="py-16 text-center">
            <School className="w-12 h-12 text-muted-foreground mx-auto mb-4" />
            <p className="text-muted-foreground mb-4">Nenhuma escola cadastrada ainda.</p>
            <Button onClick={openCreate} variant="outline" className="gap-2">
              <Plus className="w-4 h-4" />
              Cadastrar primeira escola
            </Button>
          </CardContent>
        </Card>
      ) : (
        <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          {schools.map((school) => (
            <Card key={school.id}>
              <CardContent className="p-4">
                <div className="flex items-start gap-3">
                  <div className="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center flex-shrink-0">
                    <School className="w-6 h-6 text-green-500" />
                  </div>
                  <div className="flex-1 min-w-0">
                    <h3 className="font-semibold text-foreground truncate" style={{ fontFamily: "Poppins, sans-serif" }}>
                      {school.name}
                    </h3>
                    {(school.city || school.state) && (
                      <p className="text-sm text-muted-foreground">
                        {[school.city, school.state].filter(Boolean).join(", ")}
                      </p>
                    )}
                  </div>
                </div>
                <div className="flex gap-2 mt-4">
                  <Button variant="outline" size="sm" className="flex-1 gap-1.5" onClick={() => openEdit(school)}>
                    <Pencil className="w-3.5 h-3.5" />
                    Editar
                  </Button>
                  <Button
                    variant="outline"
                    size="sm"
                    className="text-destructive hover:text-destructive hover:bg-destructive/10"
                    onClick={() => {
                      if (confirm(`Remover "${school.name}"?`)) deleteMutation.mutate({ id: school.id });
                    }}
                  >
                    <Trash2 className="w-3.5 h-3.5" />
                  </Button>
                </div>
              </CardContent>
            </Card>
          ))}
        </div>
      )}

      {/* School Dialog */}
      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>
        <DialogContent className="max-w-md">
          <DialogHeader>
            <DialogTitle style={{ fontFamily: "Poppins, sans-serif" }}>
              {editingSchool ? "Editar Escola" : "Nova Escola"}
            </DialogTitle>
          </DialogHeader>
          <div className="space-y-4 py-2">
            <div className="space-y-1.5">
              <Label>Nome da escola *</Label>
              <Input
                value={form.name}
                onChange={(e) => setForm((f) => ({ ...f, name: e.target.value }))}
                placeholder="Ex: Escola Estadual São Paulo"
              />
            </div>
            <div className="grid grid-cols-2 gap-4">
              <div className="space-y-1.5">
                <Label>Cidade</Label>
                <Input
                  value={form.city}
                  onChange={(e) => setForm((f) => ({ ...f, city: e.target.value }))}
                  placeholder="Ex: São Paulo"
                />
              </div>
              <div className="space-y-1.5">
                <Label>Estado</Label>
                <Input
                  value={form.state}
                  onChange={(e) => setForm((f) => ({ ...f, state: e.target.value }))}
                  placeholder="Ex: SP"
                  maxLength={2}
                />
              </div>
            </div>
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => setDialogOpen(false)}>
              Cancelar
            </Button>
            <Button onClick={handleSubmit} disabled={createMutation.isPending || updateMutation.isPending}>
              {editingSchool ? "Salvar" : "Cadastrar"}
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </div>
  );
}
